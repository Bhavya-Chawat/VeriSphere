<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>VeriSphere Verification Report</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
        @import url('https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;500&display=swap');
        
        * { box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            color: #111827;
            margin: 0;
            padding: 0;
            background: #ffffff;
            font-size: 11pt;
            line-height: 1.5;
        }
        .page {
            page-break-after: always;
            padding: 40px;
            position: relative;
        }
        .page:last-child {
            page-break-after: auto;
        }
        .header {
            border-bottom: 2px solid #E5E7EB;
            padding-bottom: 10px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }
        .logo { font-size: 24pt; font-weight: 700; color: #1B3A6B; letter-spacing: -0.5px; }
        .report-meta { text-align: right; font-size: 9pt; color: #6B7280; }
        h1 { font-size: 20pt; color: #1B3A6B; margin-top: 0; border-bottom: 1px solid #E5E7EB; padding-bottom: 8px; }
        h2 { font-size: 14pt; color: #1F2937; margin-top: 24px; margin-bottom: 12px; }
        h3 { font-size: 11pt; color: #374151; font-weight: 600; margin-top: 16px; margin-bottom: 8px; }
        p { margin-top: 0; margin-bottom: 12px; color: #4B5563; }
        
        .score-box { background: #F3F4F6; border-radius: 12px; padding: 30px; text-align: center; border: 1px solid #E5E7EB; margin-bottom: 30px; }
        .score-value { font-size: 48pt; font-weight: 700; color: #2563EB; line-height: 1; }
        .score-label { font-size: 12pt; color: #6B7280; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; margin-top: 8px; }
        
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 10pt; }
        th { background: #F9FAFB; text-align: left; padding: 12px; border-bottom: 2px solid #E5E7EB; color: #374151; font-weight: 600; }
        td { padding: 12px; border-bottom: 1px solid #E5E7EB; color: #4B5563; }
        
        .badge { display: inline-block; padding: 3px 8px; border-radius: 4px; font-size: 8pt; font-weight: 600; text-transform: uppercase; }
        .badge-red { background: #FDE8E8; color: #9B1C1C; border: 1px solid #F8B4B4; }
        
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .card { background: #F9FAFB; border: 1px solid #E5E7EB; padding: 20px; border-radius: 8px; margin-bottom: 20px; }
        
        .resume-container {
            font-family: 'Roboto Mono', monospace;
            font-size: 9pt;
            background: #F9FAFB;
            padding: 20px;
            border-radius: 8px;
            border: 1px solid #E5E7EB;
            white-space: pre-wrap;
        }

        .footer { position: absolute; bottom: 40px; left: 40px; right: 40px; border-top: 1px solid #E5E7EB; padding-top: 10px; font-size: 8pt; color: #9CA3AF; display: flex; justify-content: space-between; }
        .avoid-break { page-break-inside: avoid; }
    </style>
</head>
<body>

    <!-- Page 1: Verification Summary -->
    <div class="page">
        <div class="header">
            <div class="logo">VeriSphere</div>
            <div class="report-meta">Report ID: {{jobId}}<br>{{timestamp}}</div>
        </div>
        
        <h1>1. Verification Summary</h1>
        
        <div class="score-box">
            <div class="score-value">{{trustScore}}</div>
            <div class="score-label">Verified Trust Score</div>
        </div>
        
        <div class="grid-2">
            <div class="card">
                <h3>Candidate Information</h3>
                <table style="margin-bottom: 0;">
                    <tr><td style="border: none; padding: 6px 0; font-weight: 600;">Name</td><td style="border: none; padding: 6px 0; text-align: right;">{{candidateName}}</td></tr>
                    <tr><td style="border: none; padding: 6px 0; font-weight: 600;">Email</td><td style="border: none; padding: 6px 0; text-align: right;">{{candidateEmail}}</td></tr>
                    <tr><td style="border: none; padding: 6px 0; font-weight: 600;">GitHub</td><td style="border: none; padding: 6px 0; text-align: right;"><a href="{{githubUrl}}" style="color: #2563EB; text-decoration: none;">{{githubUsername}}</a></td></tr>
                </table>
            </div>

            <div class="card">
                <h3>Skill Verification</h3>
                <table style="margin-bottom: 0;">
                    <tr><td style="border: none; padding: 6px 0; font-weight: 600;">Total Claimed Skills</td><td style="border: none; padding: 6px 0; text-align: right; font-weight: bold;">{{aiReport.resumeVerificationDashboard.claimedSkillsCount}}</td></tr>
                    <tr><td style="border: none; padding: 6px 0; font-weight: 600; color: #03543F;">Verified Skills</td><td style="border: none; padding: 6px 0; text-align: right; font-weight: bold; color: #03543F;">{{aiReport.resumeVerificationDashboard.verifiedSkillsCount}}</td></tr>
                    <tr><td style="border: none; padding: 6px 0; font-weight: 600; color: #9B1C1C;">Unverified Skills</td><td style="border: none; padding: 6px 0; text-align: right; font-weight: bold; color: #9B1C1C;">{{aiReport.resumeVerificationDashboard.unverifiedSkillsCount}}</td></tr>
                </table>
            </div>
        </div>

        <div class="grid-2">
            <div class="card">
                <h3>GitHub Intelligence</h3>
                <table style="margin-bottom: 0;">
                    <tr><td style="border: none; padding: 6px 0; font-weight: 600;">Repos Analyzed</td><td style="border: none; padding: 6px 0; text-align: right;">{{aiReport.githubVerificationDashboard.repositoryCount}}</td></tr>
                    <tr><td style="border: none; padding: 6px 0; font-weight: 600;">Ownership Score</td><td style="border: none; padding: 6px 0; text-align: right;">{{aiReport.githubVerificationDashboard.ownershipScore}} / 100</td></tr>
                    <tr><td style="border: none; padding: 6px 0; font-weight: 600;">Activity Score</td><td style="border: none; padding: 6px 0; text-align: right;">{{aiReport.githubVerificationDashboard.activityScore}} / 100</td></tr>
                </table>
            </div>

            <div class="card">
                <h3>Certificate Status</h3>
                <div style="font-size: 18pt; font-weight: bold; text-align: center; margin-top: 15px; color: #1F2937;">
                    {{aiReport.githubVerificationDashboard.certificateStatus}}
                </div>
            </div>
        </div>
        
        <div class="footer">
            <span>VeriSphere Audit Report - {{candidateName}}</span>
            <span>Page 1</span>
        </div>
    </div>

    <!-- Page 2: Verified Resume -->
    <div class="page">
        <div class="header">
            <div class="logo">VeriSphere</div>
            <div class="report-meta">Report ID: {{jobId}}<br>{{timestamp}}</div>
        </div>
        
        <h1>2. Verified Resume</h1>
        <p>The original resume layout has been preserved. Claims that could not be verified by technical evidence are highlighted.</p>
        
        <div class="resume-container">
            {{{highlightedResume}}}
        </div>
        
        <div class="footer">
            <span>VeriSphere Audit Report - {{candidateName}}</span>
            <span>Page 2</span>
        </div>
    </div>

    <!-- Page 3: AI Verification Report -->
    <div class="page">
        <div class="header">
            <div class="logo">VeriSphere</div>
            <div class="report-meta">Report ID: {{jobId}}<br>{{timestamp}}</div>
        </div>
        
        <h1>3. AI Verification Report</h1>
        
        <div class="card avoid-break">
            <h2 style="margin-top: 0;">Executive Summary</h2>
            <p style="white-space: pre-wrap;">{{aiReport.executiveSummary}}</p>
        </div>

        <div class="card avoid-break">
            <h2 style="margin-top: 0;">GitHub Analysis Summary</h2>
            <p style="white-space: pre-wrap;">{{aiReport.githubAnalysisSummary}}</p>
        </div>

        <div class="card avoid-break">
            <h2 style="margin-top: 0; color: #9B1C1C;">Risk Indicators</h2>
            {{#if aiReport.riskIndicators}}
                <ul style="margin: 0; padding-left: 20px; color: #4B5563;">
                {{#each aiReport.riskIndicators}}
                    <li style="margin-bottom: 5px;">{{this}}</li>
                {{/each}}
                </ul>
            {{else}}
                <p>No significant risks detected.</p>
            {{/if}}
        </div>

        <div class="card avoid-break">
            <h2 style="margin-top: 0;">Certificate Verification Dashboard</h2>
            {{#if aiReport.certificateVerificationDashboard}}
                <p style="white-space: pre-wrap;">{{aiReport.certificateVerificationDashboard}}</p>
            {{else}}
                <p style="font-style: italic; color: #6B7280;">No certificates were provided for forensic analysis during this verification job.</p>
            {{/if}}
        </div>

        <div class="card avoid-break" style="border-left: 4px solid #2563EB;">
            <h2 style="margin-top: 0; color: #1B3A6B;">Final Hiring Recommendation</h2>
            <p style="font-weight: 500; font-size: 12pt; white-space: pre-wrap;">{{aiReport.finalHiringRecommendation}}</p>
        </div>
        
        <div class="footer">
            <span>VeriSphere Audit Report - {{candidateName}}</span>
            <span>Page 3</span>
        </div>
    </div>

</body>
</html>
