generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Candidate {
  id                 String            @id @default(uuid())
  firstName          String
  lastName           String
  email              String
  institutionalEmail String?
  githubUrl          String?
  createdAt          DateTime          @default(now())
  jobs               VerificationJob[]
}

model VerificationJob {
  id                  String       @id @default(uuid())
  candidateId         String
  status              String       @default("QUEUED")
  startedAt           DateTime     @default(now())
  completedAt         DateTime?
  certificateDataJson String?
  createdAt           DateTime     @default(now())
  errorMsg            String?
  githubMetricsJson   String?
  resumeDataJson      String?
  report              AuditReport?
  candidate           Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model AuditReport {
  id                       String          @id @default(uuid())
  jobId                    String          @unique
  findingsSummary          String
  createdAt                DateTime        @default(now())
  riskIndicatorsJson       String
  semanticMatchJson        String
  academicVerificationJson String?
  contradictions           String[]
  trustScore               Int
  job                      VerificationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}
