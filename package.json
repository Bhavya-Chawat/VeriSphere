{
  "name": "verisphere-monorepo",
  "version": "1.0.0",
  "description": "AI-powered academic profile and skill verification platform.",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter api dev & pnpm --filter web dev",
    "build": "pnpm --recursive build",
    "lint": "pnpm --recursive lint",
    "test": "pnpm --recursive test",
    "prisma:generate": "pnpm --filter shared-config prisma:generate",
    "prisma:migrate": "pnpm --filter shared-config prisma:migrate"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "prettier": "^3.2.5",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
