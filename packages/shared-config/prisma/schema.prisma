// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String
  githubUrl String?
  jobs      VerificationJob[]
  createdAt DateTime @default(now())
}

model VerificationJob {
  id                String       @id @default(uuid())
  candidateId       String
  candidate         Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  status            String       @default("QUEUED")
  startedAt         DateTime     @default(now())
  completedAt       DateTime?
  errorMsg          String?
  githubMetricsJson String?      // Stores raw GitHub engine output
  resumeDataJson    String?      // Stores raw Forensics engine output
  certificateDataJson String?    // Stores raw Certificate Forensics output
  report            AuditReport?
  createdAt         DateTime     @default(now())
}

model AuditReport {
  id                String          @id @default(uuid())
  jobId             String          @unique
  job               VerificationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  trustScore        Int             // 0-100 overall score
  findingsSummary   String
  semanticMatchJson String          // Stores the detailed matches
  contradictions    String[]
  riskIndicatorsJson String         // Stores risks as JSON instead of a separate table
  createdAt         DateTime        @default(now())
}
